---
import { ClientRouter } from "astro:transitions";
import { cn } from "../lib/utils";
import { getLangFromUrl } from "@/i18n/utils";
import "@/styles/globals.css";

import { getSiteConfig } from "@/config";
import Footer from "../components/Footer.astro";
import LocaleSwitcher from "../components/LocaleSwitcher.astro";
import Navbar from "../components/Navbar.astro";

interface Props {
	title?: string;
	scrollSmooth: boolean;
	description?: string;
	tags?: string[];
	author?: string;
	imageOg?: string;
	canonicalURL?: string;
}

const lang = getLangFromUrl(Astro.url);
const site = getSiteConfig(lang);

const {
	title = site.title,
	description = site.description,
	tags = site.tags,
	author = site.author,
	scrollSmooth,
	canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
	imageOg = site.ogImage,
} = Astro.props;
---

<!doctype html>
<html lang={lang} class={cn({ "scroll-smooth": scrollSmooth })}>
	<head>
		<meta name="msapplication-TileColor" content="#000000" />
		<meta name="viewport" content="width=device-width" />
		<meta charset="UTF-8" />
		<meta name="generator" content={Astro.generator} />

		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content={tags.join(", ")} />
		<meta name="author" content={author} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="icon" href={site.favicon} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageOg} />
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={imageOg} />

		<title>{title}</title>
		<ClientRouter />
	</head>
	<body
		class="bg-light-theme dark:bg-dark-theme antialiased text-n700 dark:text-light-theme w-full h-screen flex flex-col"
	>
		<!-- <Navbar/> -->
    <nav
      class="container pt-4 flex items-center justify-end gap-2 text-sm"
    >
      <LocaleSwitcher />
    </nav>
    <main class="container py-12 flex gap-8 flex-col" role="main" id="top">
			<slot />
		</main>
		<Footer />
	</body>
</html>
