---
import { COLORS } from "@/config";
import FrenchIcon from "./icons/FrenchIcon";
import EnglishIcon from "./icons/EnglishIcon";

interface Props {
	name: string;
	level: string;
	description: string;
}

const { name, level, description } = Astro.props;

const icons: Record<string, any> = {
	French: FrenchIcon,
	English: EnglishIcon,
};

const Icon = icons[name];
---

<div class="flex flex-col gap-2 bg-white dark:bg-n700 p-4 rounded-md">
	{Icon && (
		<div class="w-10 h-10" style={`color: ${COLORS.primary};`}>
			<Icon width={40} height={40} fill="currentColor" />
		</div>
	)}
	<h3 class="text-lg font-bold">{name}</h3>
	<span class="text-xs font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wide">{level}</span>
	<p class="text-n700 dark:text-n200 text-sm">{description}</p>
</div>