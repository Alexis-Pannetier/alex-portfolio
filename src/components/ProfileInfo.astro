---
import { getMeConfig, getSiteConfig } from "@/config";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import ProfileImage from "./ProfileImage.astro";
import DotWave from "./DotWave.astro";
import Social from "./Social.astro";
import ProfessionTypewriter from "./ProfessionTypewriter";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const me = getMeConfig(lang);
const site = getSiteConfig(lang);
const { name } = me;
---

<div class="w-full flex items-center justify-center mt-5">
  <div class="flex items-center gap-6 w-full">
    <div class="relative border-[3px] border-primary-light dark:border-primary-dark p-1.5 rounded-full overflow-visible">
      <DotWave count={3} duration={4} />
      <ProfileImage />
    </div>
    <div class="profile-info flex flex-col gap-2 w-full">
      <div class="info">
        <h1 class="text-xl md:text-2xl lg:text-4xl xl:text-4xl text-n900 dark:text-white">
          {name}
        </h1>
        <ProfessionTypewriter client:load prefix={t("home.typewriterPrefix")} displayWords={site.display} />
      </div>
      <Social />
    </div>
  </div>
</div>