---
// config import
import { getMeConfig } from "@/config";
import { getEducation } from "@/data/education.ts";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { parseAboutMeTokens } from "@/lib/utils";
// data imports
import { getWorkExperience } from "@/data/Jobs.ts";
import EduDetail from "./EduDetail.astro";
// component imports
import JobDetails from "./JobDetails.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const me = getMeConfig(lang);
const workExperience = getWorkExperience(lang);
const education = getEducation(lang);
---

<div
	class="relative flex flex-col gap-8 text-n700 dark:text-n200 w-full mt-10 px-4"
>
	{/*Description or About me -- Section*/}
	<div class="mb-4">
	<p set:html={parseAboutMeTokens(me.aboutMe)} />
	</div>
	{/*Work experience section*/}
	<div class="mb-4">
		<h2 class="text-3xl font-bold mb-4 text-center text-primary-dark">{t("about.experiences")}</h2>
		<div class="flex flex-col gap-6">
			{workExperience.map((job) => <JobDetails jobData={job} />)}
		</div>
	</div>
	{/*Education section*/}
	<div class="mb-4">
		<h2 class="text-3xl font-bold mb-4 text-center text-primary-dark">{t("about.education")}</h2>
		<div class="flex flex-col gap-6">
			{education.filter((edu) => edu.type === "degree").map((edu) => <EduDetail eduData={edu} />)}
		</div>
	</div>
</div>