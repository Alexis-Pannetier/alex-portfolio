---
// config import
import { ME } from "@/config";
import education from "@/data/education.ts";
// data imports
import workExperience from "@/data/Jobs.ts";
import EduDetail from "./EduDetail.astro";
// component imports
import JobDetails from "./JobDetails.astro";
---

<div
	class="relative flex flex-col gap-8 text-n700 dark:text-n200 w-full mt-10 px-4"
>
	{/*Description or About me -- Section*/}
	<div class="mb-4">
	<p set:html={ME.aboutMe} />
	</div>
	{/*Work experience section*/}
	<div class="mb-4">
		<h2 class="text-3xl font-bold mb-4 text-center text-primary-dark">Experiences</h2>
		<div class="flex flex-col gap-6">
			{workExperience.map((job) => <JobDetails jobData={job} />)}
		</div>
	</div>
	{/*Education section*/}
	<div class="mb-4">
		<h2 class="text-3xl font-bold mb-4 text-center text-primary-dark">Formations</h2>
		<div class="flex flex-col gap-6">
			{education.filter((edu) => edu.type === "degree").map((edu) => <EduDetail eduData={edu} />)}
		</div>
	</div>
</div>