---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BackBtn from "@/components/BackBtn.astro";
import BackToTop from "../../components/BackToTop.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("projects");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { title, summary, tags, cover, ogImage, url } = post.data;

const { Content } = await render(post);
---

<Layout
	title={title}
	description={summary}
	imageOg={ogImage}
	scrollSmooth={true}
>
	<>
		<div class="flex justify-center mt-10">
			<BackBtn />
		</div>
		<div class="flex flex-col gap-6 justify-center items-center">
			<h1 class="text-3xl font-bold text-center">{title}</h1>
			<p class="text-sm text-n500 dark:text-primary-light">
				{tags.join(", ")}
			</p>
		</div>
		<Image
			transition:name={`${post.id}-image`}
			class="rounded-2xl"
			src={cover}
			alt="Image principale"
		/>
		<p>
			{summary}
		</p>
		<a href={url}>Voir le projet ↗</a>

		<article id="article" class="mt-8 prose dark:prose-invert">
			<Content />
		</article>
		<BackToTop />
	</>
</Layout>

<style is:global>
	h2 {
		@apply text-2xl font-bold my-4;
	}
</style>
